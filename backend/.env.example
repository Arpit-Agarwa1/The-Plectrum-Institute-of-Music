# Copy this file to .env and fill in real values.

PORT=5000
NODE_ENV=development

# MongoDB: Docker (docker compose up -d), Atlas URL, or use `memory` for dev (no install)
MONGODB_URI=mongodb://127.0.0.1:27017/plectrum
# For quick local dev without Docker, you can use:
# MONGODB_URI=memory

# Used to sign login tokens — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Allowed website URL (for browser security). Your Vite dev server:
CLIENT_URL=http://localhost:5173

# First admin user (created by npm run seed)
ADMIN_EMAIL=admin@plectrum.music
ADMIN_PASSWORD=ChangeMe123!

# Cloudinary — get keys from cloudinary.com (optional: gallery uploads fail without these)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email — optional: booking emails are skipped if SMTP is empty
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@plectrum.music

# Stripe — optional
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
