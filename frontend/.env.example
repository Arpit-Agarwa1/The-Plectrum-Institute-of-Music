# --- Local development (Vite) ---
# Where Express runs. Vite proxies /api → this origin (fixes CORS in the browser).
VITE_BACKEND_ORIGIN=http://localhost:5000

# --- Production build only ---
# Full URL to your deployed API (set when you run npm run build for Vercel, etc.)
# VITE_API_URL=https://your-api.onrender.com/api

# WhatsApp: country code + number, no + or spaces (example: 14155551234)
VITE_WHATSAPP_NUMBER=


# Home hero banner image URL (optional — defaults to Unsplash if unset)
# VITE_HERO_IMAGE_URL=https://yoursite.com/images/hero.jpg

# Google Maps: embed is usually auto; override full iframe src if needed
# VITE_MAP_EMBED_URL=

# Open in Google Maps / directions (optional — defaults to institute address)
# VITE_GOOGLE_MAPS_OPEN_URL=

# Link to your Google Business reviews (Place page or “Write a review” URL from Google)
# VITE_GOOGLE_REVIEWS_URL=

# Institute YouTube channel (optional — has a default @ handle in code)
# VITE_YOUTUBE_URL=https://www.youtube.com/@theplectruminstitute1790

# Institute Instagram (optional)
# VITE_INSTAGRAM_URL=https://www.instagram.com/theplectruminstituteofmusic/
