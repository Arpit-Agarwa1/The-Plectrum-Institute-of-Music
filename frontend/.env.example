# --- Local development (Vite) ---
# Where Express runs. Vite proxies /api → this origin (fixes CORS in the browser).
VITE_BACKEND_ORIGIN=http://localhost:5000

# --- Production build only ---
# Full URL to your deployed API (set when you run npm run build for Vercel, etc.)
# VITE_API_URL=https://your-api.onrender.com/api

# WhatsApp: country code + number, no + or spaces (example: 14155551234)
VITE_WHATSAPP_NUMBER=

# Google Maps embed URL for Contact page (optional)
VITE_MAP_EMBED_URL=

# Home hero banner image URL (optional — defaults to Unsplash if unset)
# VITE_HERO_IMAGE_URL=https://yoursite.com/images/hero.jpg
